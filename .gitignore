# ---------------------------------------------------------------------------
# Project-specific
# ---------------------------------------------------------------------------
# Runtime SQLite database and trace blobs are NOT committed. The data/
# layout (data/transformers/<id>/generations/...) is created at runtime by
# the API. We do commit the empty top-level data/ directory so the volume
# mount path exists on a fresh clone.
data/transformers/*/
data/*.db
data/*.db-journal
data/*.sqlite*
data/audit/

# Generated reports
data/reports/

# ---------------------------------------------------------------------------
# External dependency: the upstream SFRA repo lives at external/SFRA/ but is
# treated as a read-only managed dependency. Developers bring it in via
# scripts/setup_external.sh; the upstream source is NOT committed to this
# repository. The keep/wrap/replace inventory we own lives at
# external/INVENTORY.md.
# ---------------------------------------------------------------------------
external/SFRA/

# ---------------------------------------------------------------------------
# Branding assets
# ---------------------------------------------------------------------------
# The APTRANSCO logo SVG recreation IS committed (assets/branding/aptransco_logo.svg).
# Higher-resolution PNG/JPG drops are kept local — substation deployments can
# place the official asset there to override the SVG.
assets/branding/aptransco_logo.png
assets/branding/aptransco_logo.jpg
assets/branding/aptransco_logo.jpeg
!assets/branding/aptransco_logo.svg
!assets/branding/README.txt
