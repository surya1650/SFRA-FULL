# APTRANSCO SFRA platform — sample environment.
# Copy to `.env` (kept out of git) and fill in:
#     cp .env.example .env
#     vi .env

# ---------------------------------------------------------------------------
# Required for production: JWT signing secret.
# Generate one: openssl rand -hex 32
# ---------------------------------------------------------------------------
SFRA_JWT_SECRET=replace-me-with-32-bytes-of-random-hex

# Postgres password used by docker-compose for the bundled DB.
# Generate one: openssl rand -hex 16
POSTGRES_PASSWORD=replace-me-postgres-pwd

# ---------------------------------------------------------------------------
# Optional overrides — sane defaults if omitted.
# ---------------------------------------------------------------------------
# Database URL the backend uses. Compose wires this to its postgres service.
# For non-compose runs you can point it at any Postgres instance.
# SFRA_DATABASE_URL=postgresql+psycopg://sfra:${POSTGRES_PASSWORD}@db:5432/sfra

# Run Alembic migrations on container start (default: 1).
# SFRA_RUN_MIGRATIONS=1

# Seed the combination catalogue on container start (default: 1).
# SFRA_SEED_CATALOGUE=1

# Dev-only escape hatch: allow boot without SFRA_JWT_SECRET. Never set in prod.
# ALLOW_DEV_JWT_SECRET=0
